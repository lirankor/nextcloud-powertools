# nextcloud-powertools — environment configuration
# Copy to `.env` and fill in. `docker compose` reads this via `env_file: .env`.
# Mirrors config.py. Required vars are marked (REQUIRED).

# ---------------------------------------------------------------------------
# Nextcloud connection (REQUIRED)
# ---------------------------------------------------------------------------
# Base URL of your Nextcloud, no trailing slash.
NEXTCLOUD_URL=https://cloud.example.com
# Dedicated service account (an ADMIN — needed for webhook registration +
# notifications). Never the human owner's account.
NC_USER=powertools
# App-password generated in the service account's Security settings (NOT the
# login password). Required when 2FA/OIDC is enforced.
NC_APP_PASSWORD=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx

# ---------------------------------------------------------------------------
# Trigger mode — set POLL_INTERVAL>0 and/or WEBHOOK_SECRET (need at least one)
# ---------------------------------------------------------------------------
# Polling sweep interval in seconds. 0 = polling disabled (webhook-only).
# Polling is the universal path (works NC>=30); webhooks are an NC>=32 add-on.
POLL_INTERVAL=60

# Shared secret for the webhook server. Empty = webhook server DISABLED.
# If set, the worker validates this (constant-time) on each incoming hook.
# Must match what register-webhooks.sh registers. TLS is REQUIRED in front.
WEBHOOK_SECRET=
# Header carrying the secret. With "Authorization", the value is "Bearer <secret>".
WEBHOOK_HEADER=Authorization
# Route the webhook listens on (public URL = NEXTCLOUD-facing-proxy + this path).
WEBHOOK_PATH=/nc-hook
# Bind inside the container. 0.0.0.0 is intentional (container-internal);
# expose via the reverse proxy, not directly.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ---------------------------------------------------------------------------
# Tag -> action map
# ---------------------------------------------------------------------------
# JSON object (REQUIRED form when set via env — the compact "a:b,c:d" form only
# works in code/.env-file-as-value, not when Docker injects it). Defaults shown.
# TAG_ACTIONS={"extract":"extract","zip":"zip","rar":"rar","render-png":"render-png","render":"render"}

# Tag assigned to a file when its action FAILS (so you can find/retry it).
# Empty = disabled.
ERROR_TAG=powertools-error

# ---------------------------------------------------------------------------
# RAR (opt-in, default OFF)
# ---------------------------------------------------------------------------
# The `rar` ACTION (creating .rar) needs the proprietary `rar` binary, which is
# only in the image when built with --build-arg ENABLE_RAR=true, AND this set to
# true. Default image has NO rar; use the `zip`/`7z` actions instead.
ENABLE_RAR=false

# ---------------------------------------------------------------------------
# Safety limits (zip-bomb guards)
# ---------------------------------------------------------------------------
# Max total uncompressed bytes across all archive members (default 2 GiB).
MAX_UNCOMPRESSED_SIZE=2147483648
# Max number of files in an archive.
MAX_FILES=10000

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Temp scratch dir. Under /tmp so the container can run with a read-only root FS
# + tmpfs /tmp (see docker-compose.yml). Must be writable by uid 10001.
WORK_DIR=/tmp/ncpowertools
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Notifications (optional, OFF by default — needs the notifications app + admin)
# ---------------------------------------------------------------------------
NOTIFY=false
# Account used for notify + webhook registration if different from NC_USER.
# Defaults to NC_USER / NC_APP_PASSWORD when blank.
NC_ADMIN_USER=
NC_ADMIN_PASSWORD=
# Nextcloud namespace the worker operates in (polling + path resolution).
# Defaults to NC_USER when blank.
TARGET_USER=
